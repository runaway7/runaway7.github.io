{
  "expo": {
    "name": "Moments",
    "slug": "moments-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "moments",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF7F2"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Moments 需要访问您的相机来记录生活中的每一个瞬间",
        "NSMicrophoneUsageDescription": "Moments 需要访问麦克风来录制语音笔记",
        "NSPhotoLibraryUsageDescription": "Moments 需要访问相册来为日记添加配图"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF7F2"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "experiments": {
      "baseUrl": "/moments-app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Moments 需要访问您的相机来记录生活中的每一个瞬间",
          "microphonePermission": "Moments 需要访问麦克风来录制语音笔记"
        }
      ]
    ]
  }
}
